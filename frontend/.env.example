# Frontend env vars. Prefix browser-exposed values with VITE_.
# The app intentionally calls relative /api URLs so auth cookies work.
# Vite proxies /api to this backend during npm run dev.
VITE_API_PROXY_TARGET=http://localhost:8000

# Optional Resend credentials for the Vercel-style waitlist edge function.
# Get these from https://resend.com/api-keys
RESEND_API_KEY=
RESEND_AUDIENCE_ID=
