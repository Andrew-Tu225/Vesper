# Frontend env vars — prefix all with VITE_ to expose to the browser
# In development the Vite proxy forwards /api → http://localhost:8001
# Override only if you need to point at a remote API host
VITE_API_BASE_URL=/api

# Resend — for edge function to capture waitlist emails
# Get these from https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here
RESEND_AUDIENCE_ID=your_resend_audience_id_here
