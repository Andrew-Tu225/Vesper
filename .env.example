# Database
POSTGRES_USER=vesper
POSTGRES_PASSWORD=changeme
POSTGRES_DB=vesper
# Docker Compose maps Postgres to localhost:5433 for manual backend development.
# Compose services override this to use the internal db:5432 host.
DATABASE_URL=postgresql+asyncpg://vesper:changeme@localhost:5433/vesper

# Redis / Worker
REDIS_URL=redis://localhost:6379/0

# Slack
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional override when APP_BASE_URL points to a public tunnel but Google should
# keep using localhost for the callback during local development.
GOOGLE_REDIRECT_URI=

# LinkedIn
# Register app at https://www.linkedin.com/developers/apps
# Redirect URI is constructed as: {APP_BASE_URL}/api/oauth/linkedin/callback
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# OpenAI
OPENAI_API_KEY=
MODEL_CLASSIFY=gpt-4o-mini
MODEL_GENERATE=gpt-4o

# App
# 32-byte hex key for AES-256-GCM token encryption.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
APP_SECRET_KEY=
# Use a public HTTPS URL when configuring Slack webhooks/interactivity.
# Slack Interactivity Request URL: {APP_BASE_URL}/api/webhooks/slack/actions
APP_BASE_URL=http://localhost:8000
APP_FRONTEND_URL=http://localhost:5173

# Set to "development" or "production".
APP_ENV=development
