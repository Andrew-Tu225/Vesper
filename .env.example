# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=vesper
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}

# ─── Redis / Worker ──────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Slack ───────────────────────────────────────────────────────────────────
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# ─── Google / Gmail ──────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Only set when APP_BASE_URL is a public tunnel (e.g. ngrok for Slack).
# Register http://localhost:8000/api/auth/google/callback in Google Cloud Console
# and set the same value here so the session cookie stays on localhost.
GOOGLE_REDIRECT_URI=

# ─── LinkedIn ─────────────────────────────────────────────────────────────────
# Register app at https://www.linkedin.com/developers/apps
# Redirect URI must be added exactly to "Authorized redirect URLs" in the app settings
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# LINKEDIN_REDIRECT_URI is constructed from APP_BASE_URL — no separate env var needed
# Value used: {APP_BASE_URL}/api/oauth/linkedin/callback

# ─── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ─── App ─────────────────────────────────────────────────────────────────────
# 32-byte hex key for AES-256-GCM token encryption
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
APP_SECRET_KEY=
APP_BASE_URL=http://localhost:8000

# Set to "development" | "production"
APP_ENV=development
